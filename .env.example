DJANGO_SECRET_KEY=change-me-in-production
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1

DATABASE_URL=postgresql://mvp:mvp@localhost:5432/mvpdb

APP_JWT_SECRET=0123456789ABCDEF0123456789ABCDEF0123456789ABCDEF0123456789ABCDEF
APP_JWT_ACCESS_TOKEN_MINUTES=15
APP_JWT_REFRESH_TOKEN_DAYS=7

APP_AUTH_PASSWORD_RESET_MINUTES=30
APP_AUTH_PASSWORD_RESET_EXPOSE_TOKEN=true

APP_CORS_WEB_ORIGIN=http://localhost:3000
APP_CORS_ADMIN_ORIGIN=http://localhost:5173

APP_GOOGLE_CLIENT_ID=

APP_SEED_ADMIN_EMAIL=admin@example.com
APP_SEED_ADMIN_PASSWORD=Admin@123

APP_MEDIA_PUBLIC_BASE_URL=http://localhost:8080

SERVER_PORT=8080

# In CLI: log every HTTP request (method, path, status, ms). 0 = off
APP_LOG_REQUESTS=1

# Stock finance chart sync (optional overrides)
APP_STOCK_FINANCE_CHART_BATCH_SIZE=60
APP_STOCK_FINANCE_CHART_MIN_AVG_VOLUME_20=100000
APP_STOCK_FINANCE_CHART_MIN_DELAY_MS=2000
APP_STOCK_FINANCE_CHART_MAX_DELAY_MS=6000
APP_STOCK_FINANCE_CHART_MAX_RETRIES=2
APP_STOCK_FINANCE_CHART_MAX_CONSECUTIVE_FAILURES=5
